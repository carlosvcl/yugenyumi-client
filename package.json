{
  "name": "yugenyumi-client",
  "version": "1.0.0",
  "description": "Launcher Otimizado YugenYumi",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "YugenYumi Team",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.1.7",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^3.5.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.yugenyumi.client",
    "productName": "YugenYumi Client",
    "files": [
      "**/*",
      "minecraft/**/*",
      "index.html",
      "index.js",
      "config.json",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}